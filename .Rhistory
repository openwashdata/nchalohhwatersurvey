# Load required libraries
library(tidyverse)
# Count the frequency of each main drinking water source
water_source_counts <- nchalohhwatersurvey %>%
filter(!is.na(main_drinking_water_source)) %>%
count(main_drinking_water_source) %>%
arrange(desc(n))
# Plot bar chart
ggplot(water_source_counts, aes(x = reorder(main_drinking_water_source, -n), y = n)) +
geom_bar(stat = "identity", fill = "#2c7fb8") +
labs(
title = "Main Sources of Drinking Water",
x = "Drinking Water Source",
y = "Number of Communities"
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Load required library
library(tidyverse)
# Summarize count of accessibility (Yes/No) by type of nearest school
accessibility_counts <- nchalohhwatersurvey %>%
# Remove missing values in relevant columns
filter(!is.na(govt_school_accessibility), !is.na(nearest_school_type)) %>%
# Count occurrences grouped by facility type and accessibility status
count(nearest_school_type, govt_school_accessibility)
# Plot grouped bar chart
ggplot(accessibility_counts, aes(x = nearest_school_type, y = n, fill = govt_school_accessibility)) +
geom_bar(stat = "identity", position = position_dodge()) +  # grouped bars side-by-side
labs(
title = "Government School Accessibility by Facility Type",
x = "Nearest School Type",
y = "Number of Communities",
fill = "Accessible?"
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
library(tidyverse)
# Filter out rows with missing coordinates or water source
heatmap_data <- nchalohhwatersurvey %>%
filter(!is.na(latitude), !is.na(longitude), !is.na(main_drinking_water_source))
# Plot points colored by main drinking water source
ggplot(heatmap_data, aes(x = longitude, y = latitude, color = main_drinking_water_source)) +
geom_point(alpha = 0.7, size = 3) +
scale_color_brewer(palette = "Set2") +
labs(
title = "Spatial Distribution of Main Drinking Water Sources",
x = "Longitude",
y = "Latitude",
color = "Water Source"
) +
theme_minimal()
library(maps)
library(ggplot2)
library(dplyr)
# Load Malawi map data from maps package
malawi_map <- map_data("world", region = "Malawi")
# Filter your data for plotting (remove missing coords or water sources)
plot_data <- nchalohhwatersurvey %>%
filter(!is.na(latitude), !is.na(longitude), !is.na(main_drinking_water_source))
# Plot Malawi map with points colored by water source
ggplot() +
geom_polygon(data = malawi_map, aes(x = long, y = lat, group = group),
fill = "gray95", color = "black") +
geom_point(data = plot_data,
aes(x = longitude, y = latitude, color = main_drinking_water_source),
alpha = 0.7, size = 3) +
scale_color_brewer(palette = "Set2") +
coord_fixed(1.3) +  # fix aspect ratio
labs(
title = "Main Drinking Water Sources in Malawi Communities",
x = "Longitude",
y = "Latitude",
color = "Water Source"
) +
theme_minimal()
devtools::build_readme()
setup_website()
